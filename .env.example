# Database — PostgreSQL connection string (Neon, Supabase, or any Postgres host)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Session — generate with: openssl rand -hex 32
SESSION_SECRET=replace_with_random_64_char_hex_string

# Admin user seeded on first boot (only used if DB is empty)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_strong_password

# Runtime environment
NODE_ENV=production

# Port (optional — defaults to 3001)
# PORT=3001
